{
  "name": "power-down",
  "version": "1.0.0",
  "description": "A small Electron app for shutting down the computer on a timer or a schedule",
  "main": "dist/main.js",
  "author": "",
  "license": "MIT",
  "private": true,
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "start": "npm run build && electron .",
    "icon": "node assets/generate-icon.cjs",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "typescript": "^5.9.3"
  },
  "build": {
    "appId": "com.local.powerdown",
    "productName": "PowerDown",
    "files": [
      "dist/**/*",
      "index.html",
      "style.css",
      "assets/icon.png",
      "assets/vendor/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.png",
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "assets/icon.png",
      "category": "Utility"
    }
  },
  "dependencies": {
    "flatpickr": "^4.6.13"
  }
}
